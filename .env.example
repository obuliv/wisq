# Copy to .env and adjust as needed. Not committed.

# --- Postgres (document + chat metadata) ---
POSTGRES_USER=wisq
POSTGRES_PASSWORD=wisq
POSTGRES_DB=wisq
DATABASE_URL=postgresql+asyncpg://wisq:wisq@postgres:5432/wisq

# --- Qdrant (vector store) ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=documents

# --- File storage ---
UPLOAD_DIR=/data/uploads

# --- LLM provider (placeholder until the LLM deep-dive picks a provider) ---
LLM_API_KEY=

# --- CORS (dev frontend origin) ---
CORS_ORIGINS=http://localhost:3000
