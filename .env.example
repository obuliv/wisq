# Copy to .env and adjust as needed. Not committed.

# --- Postgres (document + chat metadata) ---
POSTGRES_USER=wisq
POSTGRES_PASSWORD=wisq
POSTGRES_DB=wisq
DATABASE_URL=postgresql+asyncpg://wisq:wisq@postgres:5432/wisq

# --- Qdrant (vector store) ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=documents

# --- File storage ---
UPLOAD_DIR=/data/uploads

# --- LLM provider ---
# "fake" (default) needs no credentials -- deterministic canned responses, no
# network calls. Set to "openai" to use a real model (requires OPENAI_API_KEY).
# "anthropic" is a placeholder for a future provider (see app/llm/openai_client.py's
# docstring for the swap-point pattern a future app/llm/anthropic_client.py follows).
LLM_PROVIDER=fake
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Embedding provider ---
# "fake" (default) needs no credentials -- deterministic hash-based vectors, no
# network calls. Set to "openai" to use a real embedding model (reuses
# OPENAI_API_KEY above).
EMBEDDING_PROVIDER=fake
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Sparse (BM25) embedding provider, for hybrid search ---
# "fake" (default) needs no downloads/network access -- deterministic hashed
# term-frequency, no real IDF weighting. Set to "fastembed" for a real, local
# BM25 model (Qdrant's own open-source library -- no API key, runs via ONNX,
# just a one-time model download).
SPARSE_EMBEDDING_PROVIDER=fake
BM25_MODEL=Qdrant/bm25

# --- CORS (dev frontend origin) ---
CORS_ORIGINS=http://localhost:3000
